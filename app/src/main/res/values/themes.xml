<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Trego" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/background_trego</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/background_trego</item>
    </style>

    <!-- Tema para la pantalla de carga (SplashScreen API) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/trego_orange</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/tregologo</item>
        <item name="postSplashScreenTheme">@style/Theme.Trego</item>
    </style>
</resources>
<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Configuración para depuración: Solo se aplica cuando la app es debuggeable -->
    <debug-overrides>
        <trust-anchors>
            <!-- Confiar en certificados de usuario para depuración -->
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

    <!-- Configuración base: Permite tráfico HTTP no cifrado para dominios específicos -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Permitir explícitamente HTTP para conexiones locales (emulador y dispositivo físico) -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- IP del host desde el emulador -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- IPs típicas de red local para pruebas en dispositivo físico -->
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
        <domain includeSubdomains="true">172.16.0.0</domain>
        <domain includeSubdomains="true">10.0.0.0</domain>
        <!-- localhost estándar -->
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>